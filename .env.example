ARTIFACTS_BASE_URL=https://api.artifactsmmo.com
ARTIFACTS_TOKEN=your_token_here

# Primary character (used in single-character tests)
ARTIFACTS_CHARACTER=your_character_name

# All account characters with planned roles
# primary role → secondary craft skill(s)
ARTIFACTS_CHARACTER_1=char1   # combat (main carry)
ARTIFACTS_CHARACTER_2=char2   # combat (drop farmer) → weaponcrafting
ARTIFACTS_CHARACTER_3=char3   # woodcutting [axe] → gearcrafting
ARTIFACTS_CHARACTER_4=char4   # mining [pickaxe] → weaponcrafting / gearcrafting
ARTIFACTS_CHARACTER_5=char5   # alchemy/plants [gloves] + fishing → cooking, jewelrycrafting, alchemy
